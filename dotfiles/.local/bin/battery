#!/usr/bin/env bash

current=$(powerprofilesctl get)

chosen=$(echo -e "ΎΑκ  Performance\nΎΗΗ  Balanced\nΎΒυ  Power Saver" | rofi -dmenu -p "$current" -theme ~/.config/rofi/applets/type-3/battery.rasi)

case "$chosen" in
    *Performance) powerprofilesctl set performance && notify-send "Power Profile" "Performance" ;;
    *Balanced)    powerprofilesctl set balanced    && notify-send "Power Profile" "Balanced" ;;
    *Power*)      powerprofilesctl set power-saver && notify-send "Power Profile" "Power Saver" ;;
esac
