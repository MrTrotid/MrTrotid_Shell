#!/usr/bin/env bash

WALLPAPER_DIR="$HOME/.config/wallpapers"

FILE=$1

if [ -z "$FILE" ]; then
  notify-send "No images found in $WALLPAPER_DIR"
  exit 1
fi

wallust run "$FILE"
matugen image "$FILE" --prefer darkness 2>/dev/null || true
pywal_cava 2>/dev/null || true
swaync-client -rs &

notify-send "ColorScheme changed to '$(basename "$FILE")'"
